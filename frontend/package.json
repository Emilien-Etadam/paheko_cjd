{
	"name": "paheko-frontend",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "npm run build:admin && npm run build:brindille",
		"preview": "vite preview",
		"lint": "npm run lint:js && npm run lint:css",
		"lint:js": "eslint .",
		"lint:css": "stylelint \"src/admin/**/*.css\" \"src/brindille/**/*.css\"",
		"build:admin": "vite build",
		"build:brindille": "vite build --config vite.brindille.config.js"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.1.8",
		"tailwindcss": "^4.1.8",
		"vite": "^6.3.5",
		"@eslint/js": "^9.28.0",
		"eslint": "^9.28.0",
		"globals": "^16.2.0",
		"stylelint": "^16.19.1",
		"stylelint-config-standard": "^38.0.0"
	}
}
